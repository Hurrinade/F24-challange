# Convex client URL used by the frontend application.
VITE_CONVEX_URL=https://your-deployment.convex.cloud

# Public site URL used by Convex auth and callbacks.
VITE_CONVEX_SITE_URL=http://localhost:5173

# Optional for Convex local workflows such as `npx convex dev`.
CONVEX_DEPLOYMENT=dev:your-project-name

# Clerk
VITE_PUBLIC_CLERK_SIGN_IN_FORCE_REDIRECT_URL="/home"
VITE_PUBLIC_CLERK_SIGN_UP_FORCE_REDIRECT_URL="/home"

# Clerk publishable key from the Clerk dashboard.
VITE_CLERK_PUBLISHABLE_KEY=pk_test_example

### IN CONVEX ENVIRONMENT VARIABLES also need to be setup in clerk
# Used for jwt verification
CLERK_JWT_ISSUER_DOMAIN
# Used to get clerk user and store to convex (api layer handling)
CLERK_WEBHOOK_SECRET